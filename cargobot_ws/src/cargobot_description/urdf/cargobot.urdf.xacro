<?xml version="1.0"?>
<!-- CargoBot - TEKNOFEST 2026 SRUY otonom forklift mobil robot -->
<!-- Diferansiyel surus + 2D lidar + kamera + forklift catali (prismatic) -->
<robot name="cargobot" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ===================== Parametreler ===================== -->
  <xacro:property name="base_len"   value="0.70"/>   <!-- govde uzunluk (m) -->
  <xacro:property name="base_wid"   value="0.50"/>   <!-- govde genislik -->
  <xacro:property name="base_hgt"   value="0.20"/>   <!-- govde yukseklik -->
  <xacro:property name="wheel_r"    value="0.075"/>  <!-- teker yaricap -->
  <xacro:property name="wheel_w"    value="0.04"/>   <!-- teker kalinlik -->
  <xacro:property name="wheel_sep"  value="0.46"/>   <!-- tekerler arasi mesafe -->
  <xacro:property name="mass_base"  value="20.0"/>

  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12.0}" ixy="0" ixz="0"
               iyy="${m*(x*x+z*z)/12.0}" iyz="0"
               izz="${m*(x*x+y*y)/12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cyl_inertia" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+l*l)/12.0}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+l*l)/12.0}" iyz="0"
               izz="${m*r*r/2.0}"/>
    </inertial>
  </xacro:macro>

  <!-- ===================== Govde ===================== -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry><box size="${base_len} ${base_wid} ${base_hgt}"/></geometry>
      <material name="orange"><color rgba="0.95 0.5 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><box size="${base_len} ${base_wid} ${base_hgt}"/></geometry>
    </collision>
    <xacro:box_inertia m="${mass_base}" x="${base_len}" y="${base_wid}" z="${base_hgt}"/>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_r + base_hgt/2}"/>
  </joint>

  <!-- ===================== Tahrik tekerleri ===================== -->
  <xacro:macro name="drive_wheel" params="name y">
    <link name="${name}_link">
      <visual>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
        <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
      </collision>
      <xacro:cyl_inertia m="1.0" r="${wheel_r}" l="${wheel_w}"/>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="${-base_len/4} ${y} ${-base_hgt/2}"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel name="left_wheel"  y="${ wheel_sep/2}"/>
  <xacro:drive_wheel name="right_wheel" y="${-wheel_sep/2}"/>

  <!-- ===================== Castor (on serbest teker) ===================== -->
  <link name="caster_link">
    <visual><geometry><sphere radius="${wheel_r/2}"/></geometry></visual>
    <collision>
      <geometry><sphere radius="${wheel_r/2}"/></geometry>
      <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
    </collision>
    <inertial><mass value="0.2"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
    </inertial>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="${base_len/3} 0 ${-base_hgt/2 - wheel_r/2}"/>
  </joint>

  <!-- ===================== Forklift catali (prismatic - dikey) ===================== -->
  <link name="fork_link">
    <visual>
      <geometry><box size="0.30 0.40 0.03"/></geometry>
      <material name="grey"><color rgba="0.6 0.6 0.6 1"/></material>
    </visual>
    <collision><geometry><box size="0.30 0.40 0.03"/></geometry></collision>
    <xacro:box_inertia m="2.0" x="0.30" y="0.40" z="0.03"/>
  </link>
  <joint name="fork_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="fork_link"/>
    <origin xyz="${base_len/2 + 0.15} 0 ${-base_hgt/2 + 0.02}"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.25" effort="200" velocity="0.1"/>
  </joint>

  <!-- ===================== 2D Lidar ===================== -->
  <link name="laser_link">
    <visual><geometry><cylinder radius="0.04" length="0.05"/></geometry>
      <material name="blue"><color rgba="0.1 0.1 0.8 1"/></material></visual>
    <collision><geometry><cylinder radius="0.04" length="0.05"/></geometry></collision>
    <xacro:cyl_inertia m="0.2" r="0.04" l="0.05"/>
  </link>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="${base_len/2 - 0.05} 0 ${base_hgt/2 + 0.03}"/>
  </joint>

  <!-- ===================== Kamera (cizgi takibi + QR) ===================== -->
  <link name="camera_link">
    <visual><geometry><box size="0.03 0.08 0.03"/></geometry>
      <material name="red"><color rgba="0.8 0.1 0.1 1"/></material></visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <!-- one bakacak ve hafif asagi egik: zemindeki cizgi/QR icin -->
    <origin xyz="${base_len/2} 0 ${base_hgt/2 - 0.02}" rpy="0 0.5 0"/>
  </joint>
  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
    <origin rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- IMU -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/><child link="imu_link"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- ===================== Gazebo eklentileri ===================== -->
  <xacro:include filename="$(find cargobot_description)/urdf/cargobot.gazebo.xacro"/>

</robot>
