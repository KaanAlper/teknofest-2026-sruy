<?xml version="1.0"?>
<!-- TEKNOFEST 2026 SRUY - basitlestirilmis fabrika ic lojistik sahasi.
     Sekil-1'deki layout'a yakin: baslangic alani, alma/birakma noktalari,
     kontrollu kapi bolgesi, kosatlar. Olculer yaklasik (metre). -->
<sdf version="1.7">
  <world name="factory">

    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <scene><ambient>0.6 0.6 0.6 1</ambient><background>0.7 0.7 0.7 1</background></scene>

    <physics name="default" type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- ============ Dis duvarlar (12m x 8m saha) ============ -->
    <model name="walls">
      <static>true</static>
      <link name="link">
        <!-- kuzey -->
        <collision name="n_c"><pose>0 4 0.5 0 0 0</pose>
          <geometry><box><size>12 0.1 1</size></box></geometry></collision>
        <visual name="n_v"><pose>0 4 0.5 0 0 0</pose>
          <geometry><box><size>12 0.1 1</size></box></geometry>
          <material><ambient>0.5 0.5 0.55 1</ambient></material></visual>
        <!-- guney -->
        <collision name="s_c"><pose>0 -4 0.5 0 0 0</pose>
          <geometry><box><size>12 0.1 1</size></box></geometry></collision>
        <visual name="s_v"><pose>0 -4 0.5 0 0 0</pose>
          <geometry><box><size>12 0.1 1</size></box></geometry>
          <material><ambient>0.5 0.5 0.55 1</ambient></material></visual>
        <!-- bati -->
        <collision name="w_c"><pose>-6 0 0.5 0 0 0</pose>
          <geometry><box><size>0.1 8 1</size></box></geometry></collision>
        <visual name="w_v"><pose>-6 0 0.5 0 0 0</pose>
          <geometry><box><size>0.1 8 1</size></box></geometry>
          <material><ambient>0.5 0.5 0.55 1</ambient></material></visual>
        <!-- dogu -->
        <collision name="e_c"><pose>6 0 0.5 0 0 0</pose>
          <geometry><box><size>0.1 8 1</size></box></geometry></collision>
        <visual name="e_v"><pose>6 0 0.5 0 0 0</pose>
          <geometry><box><size>0.1 8 1</size></box></geometry>
          <material><ambient>0.5 0.5 0.55 1</ambient></material></visual>
      </link>
    </model>

    <!-- ============ Ic bolme + kapi cercevesi (orta duvar, ortada bosluk) ============ -->
    <model name="partition">
      <static>true</static>
      <link name="link">
        <collision name="p1_c"><pose>0 2.5 0.5 0 0 0</pose>
          <geometry><box><size>0.1 3 1</size></box></geometry></collision>
        <visual name="p1_v"><pose>0 2.5 0.5 0 0 0</pose>
          <geometry><box><size>0.1 3 1</size></box></geometry>
          <material><ambient>0.4 0.4 0.45 1</ambient></material></visual>
        <collision name="p2_c"><pose>0 -2.5 0.5 0 0 0</pose>
          <geometry><box><size>0.1 3 1</size></box></geometry></collision>
        <visual name="p2_v"><pose>0 -2.5 0.5 0 0 0</pose>
          <geometry><box><size>0.1 3 1</size></box></geometry>
          <material><ambient>0.4 0.4 0.45 1</ambient></material></visual>
      </link>
    </model>

    <!-- ============ Kontrollu kapi (PLC ile kontrol; prismatic surgu) ============ -->
    <model name="controlled_door">
      <pose>0 0 0.5 0 0 0</pose>
      <link name="door_link">
        <collision name="c"><geometry><box><size>0.12 2 1</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.12 2 1</size></box></geometry>
          <material><ambient>0.8 0.1 0.1 1</ambient></material></visual>
        <inertial><mass>10</mass>
          <inertia ixx="3.5" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="3.5"/></inertial>
      </link>
      <joint name="door_slide" type="prismatic">
        <parent>world</parent><child>door_link</child>
        <axis><xyz>0 1 0</xyz><limit><lower>0</lower><upper>2.0</upper></limit></axis>
      </joint>
      <!-- /factory_door/cmd (std_msgs/Float64) ile kapi acilip kapanir -->
      <plugin name="door_ctrl" filename="libgazebo_ros_joint_pose_trajectory.so">
        <ros><namespace>/factory_door</namespace></ros>
        <update_rate>20</update_rate>
      </plugin>
    </model>

    <!-- ============ Yere monte QR kod isaretcileri (gorsel kutucuk) ============ -->
    <!-- Gercekte ArUco texture'li duzlemler kullanilir; burada konum referansi -->
    <model name="qr_pickup_1"><static>true</static><pose>-4.5 2.5 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.3 0.3 0.02</size></box></geometry>
        <material><ambient>0 0 0 1</ambient></material></visual></link></model>
    <model name="qr_dropoff_1"><static>true</static><pose>4.5 2.5 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.3 0.3 0.02</size></box></geometry>
        <material><ambient>0 0 0 1</ambient></material></visual></link></model>
    <model name="qr_door_q5"><static>true</static><pose>-1.5 0 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.3 0.3 0.02</size></box></geometry>
        <material><ambient>0 0 0 1</ambient></material></visual></link></model>

    <!-- ============ Yer cizgileri (hassas konumlanma icin renkli serit) ============ -->
    <model name="line_pickup"><static>true</static><pose>-3.4 2.5 0.005 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>1.5 0.08 0.005</size></box></geometry>
        <material><ambient>1 0.9 0 1</ambient></material></visual></link></model>
    <model name="line_dropoff"><static>true</static><pose>3.4 2.5 0.005 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>1.5 0.08 0.005</size></box></geometry>
        <material><ambient>1 0.9 0 1</ambient></material></visual></link></model>

    <!-- ============ Palet (alma noktasinda, ~5kg sembolik yuk) ============ -->
    <model name="pallet_load"><pose>-5.0 2.5 0.06 0 0 0</pose>
      <link name="l">
        <inertial><mass>5</mass>
          <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/></inertial>
        <collision name="c"><geometry><box><size>0.4 0.4 0.12</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.4 0.4 0.12</size></box></geometry>
          <material><ambient>0.6 0.4 0.2 1</ambient></material></visual>
      </link>
    </model>

  </world>
</sdf>
