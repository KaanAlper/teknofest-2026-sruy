<?xml version="1.0"?>
<!--
  CargoBot diferansiyel sürüş forklift modeli.
  ROS2 + Gazebo Classic için. Mecanum yerine 2 tahrik + 2 caster — sade ve
  yarışma için yeterli. Forklift çatalı için lineer joint var.

  Ölçüler şartname Şekil-3 (azami robot ölçüleri) için makul varsayılan;
  gerçek robotla doğrulanıp güncellenecek.
-->
<robot name="cargobot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="base_w" value="0.40"/>      <!-- genişlik -->
  <xacro:property name="base_l" value="0.55"/>      <!-- uzunluk -->
  <xacro:property name="base_h" value="0.10"/>      <!-- yükseklik -->
  <xacro:property name="wheel_r" value="0.075"/>    <!-- tahrik tekerlek yarıçap -->
  <xacro:property name="wheel_w" value="0.04"/>
  <xacro:property name="wheel_sep" value="0.36"/>   <!-- iki tahrik arası -->
  <xacro:property name="caster_r" value="0.035"/>
  <xacro:property name="lidar_h" value="0.20"/>     <!-- LIDAR montaj yüksekliği -->
  <xacro:property name="fork_len" value="0.30"/>

  <!-- ============ INERTIAL HELPER ============ -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12}" iyy="${m*(x*x+z*z)/12}" izz="${m*(x*x+y*y)/12}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cyl_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" iyy="${m*(3*r*r+h*h)/12}" izz="${m*r*r/2}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- ============ BASE ============ -->
  <link name="base_link">
    <visual>
      <geometry><box size="${base_l} ${base_w} ${base_h}"/></geometry>
      <material name="orange"><color rgba="0.95 0.55 0.10 1"/></material>
    </visual>
    <collision>
      <geometry><box size="${base_l} ${base_w} ${base_h}"/></geometry>
    </collision>
    <xacro:box_inertia m="8.0" x="${base_l}" y="${base_w}" z="${base_h}"/>
  </link>

  <!-- ============ TEKERLEKLER ============ -->
  <xacro:macro name="drive_wheel" params="prefix y_off">
    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
        <material name="black"><color rgba="0.05 0.05 0.05 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
        <surface>
          <friction><ode><mu>1.2</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <xacro:cyl_inertia m="0.6" r="${wheel_r}" h="${wheel_w}"/>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="-0.05 ${y_off} ${-base_h/2}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel prefix="left"  y_off=" ${wheel_sep/2}"/>
  <xacro:drive_wheel prefix="right" y_off="-${wheel_sep/2}"/>

  <xacro:macro name="caster" params="prefix x_off">
    <link name="${prefix}_caster">
      <visual>
        <geometry><sphere radius="${caster_r}"/></geometry>
        <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
      </visual>
      <collision>
        <geometry><sphere radius="${caster_r}"/></geometry>
        <surface><friction><ode><mu>0.05</mu><mu2>0.05</mu2></ode></friction></surface>
      </collision>
      <inertial><mass value="0.1"/><inertia ixx="1e-4" iyy="1e-4" izz="1e-4" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>
    <joint name="${prefix}_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_caster"/>
      <origin xyz="${x_off} 0 ${-base_h/2 - caster_r + 0.001}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>
  <xacro:caster prefix="rear" x_off="-${base_l/2 - caster_r}"/>

  <!-- ============ LIDAR ============ -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.05"/></geometry>
      <material name="blue"><color rgba="0.1 0.3 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.05"/></geometry>
    </collision>
    <xacro:cyl_inertia m="0.2" r="0.04" h="0.05"/>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="${base_l/2 - 0.05} 0 ${base_h/2 + lidar_h}" rpy="0 0 0"/>
  </joint>

  <!-- ============ KAMERA ============ -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.04 0.08 0.04"/></geometry>
      <material name="dark"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <!-- Forklift çatalına bakacak şekilde öne eğimli -->
    <origin xyz="${base_l/2 - 0.02} 0 ${base_h/2 + 0.10}" rpy="0 0.35 0"/>
  </joint>

  <!-- ============ FORKLIFT ============ -->
  <link name="fork_lift">
    <visual>
      <geometry><box size="${fork_len} 0.25 0.02"/></geometry>
      <material name="silver"><color rgba="0.8 0.8 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><box size="${fork_len} 0.25 0.02"/></geometry>
    </collision>
    <xacro:box_inertia m="1.0" x="${fork_len}" y="0.25" z="0.02"/>
  </link>
  <joint name="fork_lift_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="fork_lift"/>
    <origin xyz="${base_l/2 + fork_len/2} 0 ${-base_h/2 + 0.01}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.15" effort="100" velocity="0.1"/>
  </joint>

  <!-- ============ GAZEBO PLUGIN'LERİ ============ -->

  <!-- Diferansiyel sürüş -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros><namespace>/</namespace></ros>
      <update_rate>50</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_sep}</wheel_separation>
      <wheel_diameter>${2*wheel_r}</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- 2D LIDAR -->
  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan><horizontal>
          <samples>360</samples><resolution>1</resolution>
          <min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle>
        </horizontal></scan>
        <range><min>0.12</min><max>12.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/</namespace><remapping>~/out:=scan</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- RGB kamera -->
  <gazebo reference="camera_link">
    <sensor type="camera" name="camera">
      <update_rate>15</update_rate>
      <camera>
        <horizontal_fov>1.2</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.05</near><far>10</far></clip>
      </camera>
      <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
        <ros><namespace>/camera</namespace></ros>
        <camera_name>color</camera_name>
        <frame_name>camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>
